# Google OAuth (from Google Cloud Console — Web application credential)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# Name of the JSON file stored in the user's Google Drive
DRIVE_FILE_NAME=food-log-data.json
